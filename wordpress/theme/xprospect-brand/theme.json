{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "useRootPaddingAwareAlignments": true,
    "layout": {
      "contentSize": "1280px",
      "wideSize": "1440px"
    },
    "color": {
      "custom": false,
      "defaultPalette": false,
      "palette": [
        {
          "name": "Primary",
          "slug": "primary",
          "color": "#133A63"
        },
        {
          "name": "Primary Light",
          "slug": "primary-light",
          "color": "#2F80ED"
        },
        {
          "name": "Accent",
          "slug": "accent",
          "color": "#3DD5F3"
        },
        {
          "name": "Background",
          "slug": "background",
          "color": "#FFFFFF"
        },
        {
          "name": "Section",
          "slug": "section",
          "color": "#F7F9FC"
        },
        {
          "name": "Dark",
          "slug": "dark",
          "color": "#101828"
        }
      ]
    },
    "typography": {
      "customFontSize": false,
      "defaultFontSizes": false,
      "fontFamilies": [
        {
          "name": "Manrope",
          "slug": "manrope",
          "fontFamily": "Manrope, Inter, 'Noto Sans JP', sans-serif"
        },
        {
          "name": "Inter",
          "slug": "inter",
          "fontFamily": "Inter, Manrope, 'Noto Sans JP', sans-serif"
        },
        {
          "name": "Noto Sans JP",
          "slug": "noto-sans-jp",
          "fontFamily": "'Noto Sans JP', Manrope, Inter, sans-serif"
        }
      ],
      "fontSizes": [
        {
          "name": "Small",
          "slug": "small",
          "size": "clamp(0.875rem, 0.84rem + 0.18vw, 1rem)"
        },
        {
          "name": "Base",
          "slug": "base",
          "size": "clamp(1rem, 0.96rem + 0.2vw, 1.125rem)"
        },
        {
          "name": "Large",
          "slug": "large",
          "size": "clamp(1.25rem, 1.12rem + 0.65vw, 1.625rem)"
        },
        {
          "name": "XL",
          "slug": "xl",
          "size": "clamp(1.75rem, 1.36rem + 1.95vw, 3rem)"
        },
        {
          "name": "XXL",
          "slug": "xxl",
          "size": "clamp(2.25rem, 1.6rem + 3.25vw, 4.5rem)"
        }
      ]
    },
    "spacing": {
      "customSpacingSize": false,
      "spacingScale": {
        "steps": 0
      },
      "spacingSizes": [
        {
          "name": "4",
          "slug": "4",
          "size": "4px"
        },
        {
          "name": "8",
          "slug": "8",
          "size": "8px"
        },
        {
          "name": "12",
          "slug": "12",
          "size": "12px"
        },
        {
          "name": "16",
          "slug": "16",
          "size": "16px"
        },
        {
          "name": "24",
          "slug": "24",
          "size": "24px"
        },
        {
          "name": "32",
          "slug": "32",
          "size": "32px"
        },
        {
          "name": "48",
          "slug": "48",
          "size": "48px"
        },
        {
          "name": "64",
          "slug": "64",
          "size": "64px"
        },
        {
          "name": "96",
          "slug": "96",
          "size": "96px"
        },
        {
          "name": "128",
          "slug": "128",
          "size": "128px"
        }
      ]
    },
    "border": {
      "color": true,
      "radius": true,
      "style": true,
      "width": true
    },
    "shadow": {
      "defaultPresets": false,
      "presets": [
        {
          "name": "Soft",
          "slug": "soft",
          "shadow": "0 8px 30px rgba(16, 24, 40, 0.08)"
        },
        {
          "name": "Medium",
          "slug": "medium",
          "shadow": "0 16px 48px rgba(16, 24, 40, 0.12)"
        }
      ]
    },
    "custom": {
      "layout": {
        "container": "1280px",
        "gridDesktop": "1440px"
      },
      "radius": {
        "button": "16px",
        "card": "24px",
        "image": "32px"
      }
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--background)",
      "text": "var(--wp--preset--color--dark)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--manrope)",
      "fontSize": "var(--wp--preset--font-size--base)",
      "lineHeight": "1.65"
    },
    "spacing": {
      "blockGap": "var(--wp--preset--spacing--24)",
      "padding": {
        "right": "var(--wp--preset--spacing--16)",
        "left": "var(--wp--preset--spacing--16)"
      }
    },
    "elements": {
      "button": {
        "border": {
          "radius": "var(--wp--custom--radius--button)"
        },
        "color": {
          "background": "var(--wp--preset--color--primary)",
          "text": "var(--wp--preset--color--background)"
        },
        "spacing": {
          "padding": {
            "top": "14px",
            "right": "24px",
            "bottom": "14px",
            "left": "24px"
          }
        },
        "typography": {
          "fontWeight": "700",
          "lineHeight": "1.2"
        }
      },
      "link": {
        "color": {
          "text": "var(--wp--preset--color--primary-light)"
        }
      }
    },
    "blocks": {
      "core/button": {
        "border": {
          "radius": "var(--wp--custom--radius--button)"
        }
      },
      "core/image": {
        "border": {
          "radius": "var(--wp--custom--radius--image)"
        }
      }
    }
  },
  "templateParts": [
    {
      "name": "header",
      "title": "Header",
      "area": "header"
    },
    {
      "name": "footer",
      "title": "Footer",
      "area": "footer"
    }
  ],
  "customTemplates": [
    {
      "name": "page-ai",
      "title": "AI導入支援",
      "postTypes": [
        "page"
      ]
    },
    {
      "name": "page-services",
      "title": "サービス",
      "postTypes": [
        "page"
      ]
    },
    {
      "name": "page-technology",
      "title": "技術",
      "postTypes": [
        "page"
      ]
    },
    {
      "name": "page-recruit",
      "title": "採用情報",
      "postTypes": [
        "page"
      ]
    },
    {
      "name": "page-company",
      "title": "会社情報",
      "postTypes": [
        "page"
      ]
    },
    {
      "name": "page-contact",
      "title": "お問い合わせ",
      "postTypes": [
        "page"
      ]
    }
  ]
}
